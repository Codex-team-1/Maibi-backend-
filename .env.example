NODE_ENV=production
PORT=3000

# MongoDB Atlas connection string (required)
PRO_MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/maibi?retryWrites=true&w=majority
# Local MongoDB for development only (optional — falls back to PRO_MONGODB_URI when absent)
DEV_MONGODB_URI=mongodb://localhost:27017/maibi

# Auth — use a 64-char random string (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-64-char-secret
JWT_EXPIRES_IN=7d

# Admin account — created automatically on first boot if it doesn't exist
ADMIN_EMAIL=admin@maibi.dz
ADMIN_PASSWORD=change-me-strong-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=your-key
CLOUDINARY_API_SECRET=your-secret
CLOUDINARY_FOLDER=maibi

# CORS — set to your production frontend domain (no trailing slash)
CORS_ORIGIN=https://maibi.dz

# Email (Resend)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@maibi.dz
EMAIL_FROM_NAME=Maibi
